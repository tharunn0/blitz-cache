import http from "k6/http";
import { check } from "k6";

const BASE = "http://localhost:1100/api/v1";

export const options = {
  vus: 1000,
  duration: "60s",
};

export default function () {
  const key = Math.floor(Math.random() * 1000);

  // 20% writes
  if (Math.random() < 0.2) {
    const res = http.post(`${BASE}/set`, JSON.stringify({
      key: key,
      value: "test",
    }), {
      headers: { "Content-Type": "application/json" },
    });

    check(res, { "set ok": (r) => r.status < 500 });
  }
  // 80% reads
  else {
    const res = http.get(`${BASE}/get/${key}`);

    check(res, { "get ok": (r) => r.status < 500 });
  }
}

